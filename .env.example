# ---------------------------------------------------------------------------
# Copy this file to `.env` and adjust as needed.
#   cp .env.example .env       (bash)
#   Copy-Item .env.example .env  (PowerShell)
# ---------------------------------------------------------------------------

# --- PostgreSQL ---
PGUSER=fems
PGPASSWORD=fems_password
PGDATABASE=fems
PGHOST=localhost
PGPORT=5432
# Used by services + migration scripts. For docker-compose the host is `postgres`.
DATABASE_URL=postgres://fems:fems_password@localhost:5432/fems

# --- JWT / auth ---
JWT_SECRET=dev_access_secret_change_me
JWT_REFRESH_SECRET=dev_refresh_secret_change_me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=7

# --- Gateway / CORS ---
GATEWAY_PORT=8080
CORS_ORIGIN=*
NODE_ENV=development

# --- Frontend (Next.js) ---
# Browser talks to the gateway:
NEXT_PUBLIC_API_URL=http://localhost:8080/api
